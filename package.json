{
  "name": "flaxia",
  "version": "0.1.0",
  "description": "Chronological SNS where posts are living, interactive applications",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev dist --d1=DB --r2=BUCKET --port 8787",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "migrate:local": "wrangler d1 migrations apply flaxia --local",
    "migrate:prod": "wrangler d1 migrations apply flaxia"
  },
  "dependencies": {
    "better-auth": "^1.5.4",
    "hono": "^4.0.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.0",
    "lucide": "^0.300.0",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^3.0.0"
  },
  "packageManager": "pnpm@8.0.0"
}
