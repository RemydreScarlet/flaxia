{
  "name": "flaxia",
  "version": "0.1.0",
  "description": "Chronological SNS where posts are living, interactive applications",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev --d1=DB --r2=BUCKET -- pnpm vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "migrate:local": "wrangler d1 migrations apply flaxia --local",
    "migrate:prod": "wrangler d1 migrations apply flaxia"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@cloudflare/workers-oauth-provider": "^0.1.0",
    "katex": "^0.16.0",
    "lucide": "^0.300.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^3.0.0"
  },
  "packageManager": "pnpm@8.0.0"
}
